# ============================================================
# DataForge Configuration
# Copy this file to .env and fill in your values
# ============================================================

# OpenAI API Key (required for AI-powered analysis)
OPENAI_API_KEY=sk-your-openai-key-here

# Optional: Anthropic API Key (alternative LLM provider)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Slack Webhook URL (optional: for notifications)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Email notifications (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Notification recipient
NOTIFY_EMAIL=client@example.com

# Scraping settings
SCRAPE_HEADLESS=true
SCRAPE_TIMEOUT=30000
SCRAPE_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# Output settings
OUTPUT_DIR=./output
DATA_DIR=./data
LOG_LEVEL=INFO
